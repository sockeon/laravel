{
    "name": "sockeon/laravel",
    "description": "Laravel integration for Sockeon WebSocket and HTTP server",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "xentixar",
            "email": "xentixar@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "sockeon/sockeon": "dev-main"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Sockeon\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sockeon\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sockeon\\Laravel\\SockeonServiceProvider"
            ],
            "aliases": {
                "Sockeon": "Sockeon\\Laravel\\Facades\\Sockeon"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    }
}
